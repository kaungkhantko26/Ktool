#!/usr/bin/env sh
set -eu

if [ -n "${KTOOL_HOME:-}" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$KTOOL_HOME" && pwd)
else
  SOURCE=$0
  while [ -h "$SOURCE" ]; do
    DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
    LINK=$(readlink "$SOURCE")
    case "$LINK" in
      /*) SOURCE=$LINK ;;
      *) SOURCE=$DIR/$LINK ;;
    esac
  done
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
fi

if [ ! -f "$SCRIPT_DIR/tool.py" ]; then
  echo "[ERROR] Ktool cannot find tool.py in: $SCRIPT_DIR" >&2
  echo "        If you copied the launcher, set KTOOL_HOME to your repo path." >&2
  echo "        Example: export KTOOL_HOME=\"\$HOME/Ktool\"" >&2
  exit 1
fi

if [ "$#" -eq 0 ]; then
  python3 "$SCRIPT_DIR/tool.py"
  STATUS=$?
else
  python3 "$SCRIPT_DIR/tool.py" "$@"
  STATUS=$?
fi

if [ -f "$SCRIPT_DIR/.ktool-auto-deploy" ] && [ "${KTOOL_SKIP_AUTO_DEPLOY:-}" != "1" ]; then
  "$SCRIPT_DIR/ktool-auto-deploy.sh" run || true
fi

exit "$STATUS"
